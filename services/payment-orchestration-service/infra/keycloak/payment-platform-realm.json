{
  "realm": "payment-platform",
  "enabled": true,
  "sslRequired": "NONE",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "clients": [
    {
      "clientId": "payment-cli",
      "name": "payment-cli",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "payments.read",
        "payments.write"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "payments.read",
      "description": "Read access to payment APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "payments.write",
      "description": "Write access to payment APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "users": [
    {
      "username": "payment-user",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "paymentpass",
          "temporary": false
        }
      ]
    }
  ]
}
